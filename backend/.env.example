PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/whatsapp_campaign
JWT_SECRET=replace_with_min_32_char_random_secret_here_abc123
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=https://your-app.vercel.app

# Select provider: wati or meta
WHATSAPP_PROVIDER=wati

# WATI WhatsApp Business API (required when WHATSAPP_PROVIDER=wati)
WATI_API_ENDPOINT=https://your-tenant.wati.io
WATI_ACCESS_TOKEN=your_wati_access_token
WATI_BUSINESS_NUMBER=919999999999
WATI_CHANNEL=
WATI_WEBHOOK_VERIFY_TOKEN=your_custom_wati_webhook_verify_token
WATI_WEBHOOK_SECRET=

# Meta WhatsApp Cloud API (required when WHATSAPP_PROVIDER=meta)
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_APP_SECRET=your_meta_app_secret
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_webhook_verify_token

# Optional tunables
WHATSAPP_TEST_PHONE_NUMBER=919999999999
CAMPAIGN_CONCURRENCY=5
DELIVERY_TIMEOUT_MINUTES=30
